shipname=libsdl
shipversion=1.2.15
shipsources="https://github.com/libsdl-org/SDL-1.2/archive/refs/tags/release-1.2.15.tar.gz libsdl.patch sdl-config.sh"
shiptugs=""
shipfunnels=1

build() {
	run tar xzf release-${shipversion}.tar.gz

	cd SDL-1.2-release-${shipversion}

	msg "Patching sources..."
	# Patch sources
	patch -p 1 <../libsdl.patch

	# Run autoreconf
	msg "Building configure script..."
	./autogen.sh

	# Configure
	msg "Configuring..."

	run ./configure \
		$HSCT_CONFIGURE_ARGS \
		--target="$HSCT_CCROSS_TARGET" \
		--program-prefix="" \
		--enable-oss=no \
		--enable-alsa=no \
		--enable-jack=no \
		--enable-esd=no \
		--enable-pipewire=no \
		--enable-pulseaudio=no \
		--enable-arts=no \
		--enable-nas=no \
		--enable-sndio=no \
		--enable-video-helenos=yes \
		--enable-video-wayland=no \
		--enable-video-rpi=no \
		--enable-video-x11=no \
		--enable-video-opengl=no \
		--enable-video-vulkan=no \
		--enable-timers=no

	# Build
	msg "Building..."

	run make -j$shipfunnels \
	    CFLAGS="-D__HELENOS__"
}

package() {
	pwd
	cd SDL-1.2-release-${shipversion}
	run make install "DESTDIR=$PWD/PKG"

	run mkdir -p "$HSCT_INCLUDE_DIR/SDL"
	run cp PKG/usr/local/include/SDL/*.h "$HSCT_INCLUDE_DIR/SDL"
	run cp PKG/usr/local/lib/*.a "$HSCT_LIB_DIR/"

	run mkdir -p "$HSCT_MY_DIR/inc/c/SDL"
	run cp PKG/usr/local/include/SDL/*.h "$HSCT_MY_DIR/inc/c/SDL"

	run mkdir -p "$HSCT_MY_DIR/lib"
	run cp PKG/usr/local/lib/*.a "$HSCT_MY_DIR/lib"

	cd ..
	run mkdir -p "$HSCT_APP_DIR"
	run cp sdl-config.sh "$HSCT_APP_DIR/sdl-config"
	chmod 755 "$HSCT_APP_DIR/sdl-config"
}
