shipname=dosbox
shipversion=0.74-3
shipsources="https://unlimited.dl.sourceforge.net/project/dosbox/dosbox/0.74-3/dosbox-0.74-3.tar.gz dosbox.patch"
shiptugs=""
shipfunnels=1

build() {
	run tar xzf ${shipname}-${shipversion}.tar.gz

	cd ${shipname}-${shipversion}

	# Patch sources
	msg "Patching sources..."
	patch -p 1 <../dosbox.patch

	# Run autoreconf
	msg "Rebuilding configure script..."
	autoreconf

	# Configure
	msg "Configuring..."

	run ../${shipname}-${shipversion}/configure \
		$HSCT_CONFIGURE_ARGS \
		--target="$HSCT_CCROSS_TARGET" \
		--program-prefix=""

	# Build
	msg "Building..."

	run make -j$shipfunnels \
	    CFLAGS="-D__HELENOS__" \
	    LIBS="-lcpp -lSDL"
}

package() {
	pwd
	cd ${shipname}-${shipversion}
	run make install "DESTDIR=$PWD/PKG"

	run mkdir -p "$HSCT_MY_DIR/app"
	run cp -r PKG/usr/local/bin/dosbox "$HSCT_MY_DIR/app/dosbox"
}
